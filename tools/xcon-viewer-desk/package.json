{
  "name": "xcon-viewer-desk",
  "version": "0.1.0",
  "description": "Windows GUI shell host for cmd.exe and PowerShell, built with Electron + xterm.js + PTY.",
  "main": "./out/main/index.js",
  "author": "Xamong9",
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "npm run typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "pack:win": "npm run build && electron-builder --win --x64 --dir",
    "dist:win": "npm run build && electron-builder --win --x64",
    "dist:win:arm64": "npm run build && electron-builder --win --arm64",
    "pack:mac": "npm run build && electron-builder --mac --dir",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:mac:universal": "npm run build && electron-builder --mac --universal",
    "dist:mac:arm64": "npm run build && electron-builder --mac --arm64",
    "dist:mac:x64": "npm run build && electron-builder --mac --x64",
    "clean": "node ./scripts/clean.mjs",
    "docs:capabilities": "node ./scripts/generateCapabilityRegistryDocs.mjs",
    "playwright:install": "npx playwright install chromium",
    "check:public-release": "node ./scripts/publicReleaseCheck.mjs",
    "server": "node server/index.js",
    "server:dev": "cd server && npx nodemon index.js",
    "server:install": "cd server && npm install",
    "server:kouri-sports": "node scripts/kouriSportsToolsServer.mjs",
    "rebuild:server": "electron-rebuild -f -w better-sqlite3 -m ./server",
    "test:sidecar": "node --test scripts/xamongCodeSidecar.test.mjs",
    "test:xenesis": "node --test scripts/xenesisService.test.mjs scripts/xenesisEmbeddedService.test.mjs scripts/xenesisRuntimeLifecycle.test.mjs scripts/xenesisDeskCapabilitySource.test.mjs scripts/xenesisAgentPolicyNotices.test.mjs scripts/xenesisDeskSmokeReport.test.mjs scripts/xenesisPhase4Integration.test.mjs scripts/xenesisPhase4Completion.test.mjs scripts/xenesisPhysicalIntegration.test.mjs",
    "test:markdown-xcon": "node --test scripts/markdownPaneXcon.test.mjs",
    "test:render-streaming": "node --test scripts/renderStreaming.test.mjs",
    "test:extensions": "node --test scripts/extensions.test.mjs scripts/demoLabPresetRoundtrip.test.mjs scripts/kouriChatE2e.test.mjs",
    "test:kouri-chat-ui": "node --test scripts/kouriChatUi.playwright.test.mjs",
    "test:kouri-sports-tools": "node --test scripts/kouriSportsToolsServer.test.mjs",
    "smoke:xenesis-desk": "node scripts/xenesisDeskSmoke.mjs",
    "report:xenesis-desk": "node scripts/xenesisDeskSmokeReport.mjs",
    "smoke:kouri": "node scripts/kouriProviderSmoke.mjs",
    "smoke:kouri:codex": "node scripts/kouriProviderSmoke.mjs --providers=codex --real-cli --timeout-ms=120000",
    "smoke:kouri:chat-e2e": "node scripts/kouriChatE2eSmoke.mjs",
    "smoke:kouri:chat-e2e:codex": "node scripts/kouriChatE2eSmoke.mjs --provider=codex --real-cli --timeout-ms=120000",
    "smoke:kouri:dev-bridge": "node scripts/kouriDevBridgeSmoke.mjs",
    "smoke:kouri:dev-bridge:async": "node scripts/kouriDevBridgeSmoke.mjs --async",
    "smoke:kouri:dev-bridge:repair": "node scripts/kouriDevBridgeSmoke.mjs --force-repair-smoke --timeout-ms=60000",
    "smoke:kouri:dev-bridge:byok": "node scripts/kouriDevBridgeSmoke.mjs --provider=byok --real-api --timeout-ms=120000",
    "smoke:kouri:dev-bridge:matrix": "node scripts/kouriDevBridgeMatrixSmoke.mjs",
    "smoke:kouri:dev-bridge:matrix:byok": "node scripts/kouriDevBridgeMatrixSmoke.mjs --include-byok",
    "smoke:kouri:dev-bridge:visual": "node scripts/kouriDevBridgeVisualSmoke.mjs",
    "smoke:kouri:dev-bridge:quality": "node scripts/kouriDevBridgeQualitySmoke.mjs",
    "smoke:kouri:dev-bridge:quality:real": "node scripts/kouriDevBridgeQualitySmoke.mjs --include-real-providers",
    "smoke:kouri:acceptance": "node scripts/kouriGenerationAcceptanceSmoke.mjs",
    "test:demo-lab-ui": "node --test scripts/demoLabPlayerPane.playwright.test.mjs",
    "test:settings": "node --test scripts/settingsCatalog.test.mjs",
    "test:desk-bridge": "node --test scripts/deskBridgeFacade.test.mjs scripts/deskBridgeCapabilitiesDynamic.test.mjs scripts/capabilityExplorerTree.test.mjs scripts/xvCliBridgeCommands.test.mjs",
    "test:mcp": "node --test scripts/mcpBridge.test.mjs",
    "test:mcp-terminal": "node --test scripts/mcpTerminalControl.test.mjs",
    "smoke:xenesis-packaged": "node scripts/xenesisPackagedRuntimeSmoke.mjs",
    "test:local-cli": "node --test scripts/localCliAgents.test.mjs",
    "test:cr": "node --import tsx/esm --test \"src/cr/__tests__/*.test.ts\""
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.1",
    "@lydell/node-pty": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@pomelo-suite/timeline": "file:../../../pomelo-suite/packages/timeline",
    "@types/ssh2": "^1.15.5",
    "@uiw/react-codemirror": "^4.25.9",
    "@vscode/ripgrep": "^1.18.0",
    "@xcon-chain/core": "file:../../../xcon-chain/packages/core",
    "@xcon-viewer/core": "file:../../packages/core",
    "@xcon-viewer/viewer": "file:../../packages/viewer",
    "@xcon-workflow/core": "file:../../../xcon-workflow/packages/core",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "basic-ftp": "^6.0.1",
    "chart.js": "^4.5.1",
    "commander": "^14.0.3",
    "docx-preview": "^0.3.7",
    "electron-updater": "^6.8.3",
    "hwp.js": "^0.0.3",
    "iconv-lite": "^0.7.2",
    "jszip": "^3.10.1",
    "katex": "^0.16.45",
    "mermaid": "^11.14.0",
    "openai": "^6.42.0",
    "pdfjs-dist": "^5.7.284",
    "playwright": "^1.54.0",
    "pptxviewjs": "^1.1.9",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "ssh2": "^1.17.0",
    "xenesis": "file:packages/xenesis",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.0",
    "vite": "^7.0.0"
  },
  "build": {
    "appId": "com.xamong.xconviewer.desk",
    "productName": "XconViewer Desk",
    "copyright": "Copyright © 2026",
    "toolsets": {
      "winCodeSign": "1.0.0"
    },
    "publish": {
      "provider": "generic",
      "url": "https://update.xamong.com/xcon-viewer-desk/"
    },
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "node_modules/xenesis/**/*",
      "package.json",
      "src/main/xvDeskHome.mjs",
      "scripts/xv.mjs",
      "mcp/**/*",
      "server/**/*",
      "extensions/sample.*/*",
      {
        "from": "packaging/extensions/xv-desk-bot",
        "to": "extensions/xcon-viewer.release-xv-desk-bot",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "node_modules/@lydell/node-pty/**/*",
      "node_modules/@modelcontextprotocol/sdk/**/*",
      "node_modules/@vscode/ripgrep/**/*",
      "node_modules/@vscode/ripgrep-win32-x64/**/*",
      "node_modules/commander/**/*",
      "node_modules/openai/**/*",
      "node_modules/playwright/**/*",
      "node_modules/playwright-core/**/*",
      "node_modules/@xcon-viewer/core/**/*",
      "node_modules/@xcon-viewer/viewer/**/*",
      "node_modules/@pomelo-suite/timeline/**/*",
      "node_modules/@xcon-chain/core/**/*",
      "node_modules/@xcon-workflow/core/**/*",
      "node_modules/xenesis/**/*",
      "node_modules/zod/**/*",
      "node_modules/zod-to-json-schema/**/*",
      "src/main/xvDeskHome.mjs",
      "scripts/xv.mjs",
      "mcp/**/*",
      "server/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "XconViewer Desk",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "artifactName": "${productName}-${version}-Setup-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-Portable-${arch}.${ext}"
    },
    "artifactName": "${productName}-${version}-${arch}.${ext}"
  }
}
