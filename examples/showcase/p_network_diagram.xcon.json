        { "id": "core", "label": "Core", "x": 210, "y": 285, "color": "#14b8a6" },
        { "id": "sketch", "label": "SKETCH", "x": 400, "y": 285, "color": "#8b5cf6" },
        { "id": "docs", "label": "Docs", "x": 590, "y": 285, "color": "#db2777" }
