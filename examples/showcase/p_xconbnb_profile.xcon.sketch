        av: shape "<div class=\"xa-al-prof-hero__avatar-wrap\"><img class=\"xa-al-prof-hero__avatar\" src=\"https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=300&q=80\" width=\"108\" height=\"108\" alt=\"Profile\"><button tabindex=\"-1\" type=\"button\" class=\"xa-al-prof-hero__settings\" aria-label=\"Settings\"><svg viewBox=\"0 0 24 24\"><circle cx=\"12\" cy=\"12\" r=\"3\"/><path d=\"M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z\"/></svg></button></div>" at 0 0 200 116
          shape "rectangle"
          renderHtml true
          border
            visible false
          verticalAlign "top"
          overflow "hidden"
          style "width:auto!important;display:block;margin:0 auto 14px;box-sizing:border-box;"
          al
            alignSelf "center"
        name: label "SONYEJIN" at 0 0 560 28
