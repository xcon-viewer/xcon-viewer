<Panel border="visible:true; width:1; color:var(--border); radius:10" shadow="opacity:0.08; blur:6" pos="0,0,560,32" al="autoHeight:true; gap:10px; padding:14px 16px" componentsOrder="hdr,h08a,a08,h08b,b08">
  <Label name="hdr" text="08 · TextView" pos="0,0,560,28" font="size:11; weight:bold" textAlign="left" />
  <Label name="h08a" text="textView · rich typography (#08-A)" pos="0,0,560,28" font="size:10; weight:600" textAlign="left" />
  <Panel name="a08" border="visible:false; width:1; color:var(--border); radius:10" shadow="visible:false" pos="0,0,560,32" al="autoHeight:true; gap:20px; padding:0" componentsOrder="hdr,t1,subC,t2">
    <Label name="hdr" text=" " pos="0,0,560,28" font="size:11; weight:bold" textAlign="left" />
    <TextView name="t1" text="&lt;div class=&quot;tv-article&quot;&gt;&lt;p class=&quot;tv-lead&quot;&gt;The future of interface design lies not in complexity, but in the precise removal of everything unnecessary.&lt;/p&gt;&lt;p&gt;Good typography is the foundation of readable, accessible interfaces. It guides the eye, establishes hierarchy, and creates &lt;strong&gt;emotional resonance&lt;/strong&gt; before a single word is consciously processed.&lt;/p&gt;&lt;div class=&quot;tv-quote&quot;&gt;&lt;p&gt;&amp;quot;Design is not just what it looks like and feels like. Design is how it works.&amp;quot;&lt;/p&gt;&lt;cite&gt;&amp;mdash; Steve Jobs, 2003&lt;/cite&gt;&lt;/div&gt;&lt;p&gt;Learn more about &lt;a href=&quot;#&quot;&gt;typographic systems&lt;/a&gt; and how to apply them with &lt;em&gt;intentionality and craft&lt;/em&gt; in modern product design.&lt;/p&gt;&lt;/div&gt;" pos="0,0,560,320" renderHtml="true" textViewVariant="article" al="width:100%" editable="false" />
    <Label name="subC" text="Code Block" pos="0,0,560,28" font="size:10; weight:500" textAlign="left" color="var(--ink-3)" style="letter-spacing:2px;text-transform:uppercase;line-height:1.4;margin-top:18px;margin-bottom:12px;" />
    <TextView name="t2" text="&lt;div class=&quot;tv-code&quot;&gt;&lt;span class=&quot;tv-code__lang&quot;&gt;TypeScript&lt;/span&gt;&lt;span class=&quot;kw&quot;&gt;const&lt;/span&gt; &lt;span class=&quot;fn&quot;&gt;fetchUser&lt;/span&gt; = &lt;span class=&quot;kw&quot;&gt;async&lt;/span&gt; (id: &lt;span class=&quot;kw&quot;&gt;string&lt;/span&gt;) =&gt; {&lt;br&gt;&amp;nbsp;&amp;nbsp;&lt;span class=&quot;kw&quot;&gt;const&lt;/span&gt; res = &lt;span class=&quot;kw&quot;&gt;await&lt;/span&gt; fetch(&lt;span class=&quot;str&quot;&gt;`/api/users/${id}`&lt;/span&gt;);&lt;br&gt;&amp;nbsp;&amp;nbsp;&lt;span class=&quot;cmt&quot;&gt;// Parse and validate response&lt;/span&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&lt;span class=&quot;kw&quot;&gt;return&lt;/span&gt; res.json() &lt;span class=&quot;kw&quot;&gt;as&lt;/span&gt; User; &lt;span class=&quot;cmt&quot;&gt;// v&lt;span class=&quot;num&quot;&gt;2.1&lt;/span&gt;&lt;/span&gt;&lt;br&gt;};&lt;/div&gt;" pos="0,0,560,200" renderHtml="true" textViewVariant="code" al="width:100%" editable="false" />
  </Panel>
  <Label name="h08b" text="textView · truncate &amp; lists (#08-B)" pos="0,0,560,28" font="size:10; weight:600" textAlign="left" />
  <Panel name="b08" border="visible:false; width:1; color:var(--border); radius:10" shadow="visible:false" pos="0,0,560,32" al="autoHeight:true; gap:20px; padding:0" componentsOrder="hdr,eLabel,trunc,d1,lLabel,list,d2,mLabel,meta">
    <Label name="hdr" text=" " pos="0,0,560,28" font="size:11; weight:bold" textAlign="left" />
    <Label name="eLabel" text="Expand / Collapse Text" pos="0,0,560,28" font="size:10; weight:500" textAlign="left" color="var(--ink-3)" style="letter-spacing:2px;text-transform:uppercase;line-height:1.4;margin-top:0;margin-bottom:12px;" />
    <TextView name="trunc" text="Product design is the process of identifying a market opportunity, clearly defining the problem, developing a proper solution for that problem and validating the solution with real users. It combines &lt;span class=&quot;tv-highlight&quot;&gt;UX research&lt;/span&gt;, visual design, and engineering to create products that are both functional and delightful. A skilled product designer bridges the gap between user needs and business objectives, ensuring every decision is grounded in data and empathy." pos="0,0,560,120" renderHtml="true" textViewVariant="truncate" al="width:100%" editable="false" />
    <Label name="d1" text=" " pos="0,0,560,28" font="size:1" textAlign="left" color="transparent" labelPadding="0" style="height:1px;min-height:1px;background:var(--border);width:100%;display:block;margin:12px 0;" />
    <Label name="lLabel" text="Structured List" pos="0,0,560,28" font="size:10; weight:500" textAlign="left" color="var(--ink-3)" style="letter-spacing:2px;text-transform:uppercase;line-height:1.4;margin-top:18px;margin-bottom:12px;" />
    <TextView name="list" text="&lt;ul class=&quot;tv-list&quot;&gt;&lt;li&gt;Define the problem clearly before jumping to solutions&lt;/li&gt;&lt;li&gt;Prototype early and iterate based on user feedback&lt;/li&gt;&lt;li&gt;Measure success with both qualitative and quantitative data&lt;/li&gt;&lt;li&gt;Collaborate with engineers from day one, not after handoff&lt;/li&gt;&lt;li&gt;Prioritize accessibility as a core feature, not an afterthought&lt;/li&gt;&lt;/ul&gt;" pos="0,0,560,200" renderHtml="true" textViewVariant="list" al="width:100%" editable="false" />
    <Label name="d2" text=" " pos="0,0,560,28" font="size:1" textAlign="left" color="transparent" labelPadding="0" style="height:1px;min-height:1px;background:var(--border);width:100%;display:block;margin:12px 0;" />
    <Label name="mLabel" text="Metadata Block" pos="0,0,560,28" font="size:10; weight:500" textAlign="left" color="var(--ink-3)" style="letter-spacing:2px;text-transform:uppercase;line-height:1.4;margin-top:18px;margin-bottom:12px;" />
    <TextView name="meta" text="&lt;div style=&quot;display:grid;grid-template-columns:auto 1fr;gap:6px 16px;font-size:12px&quot;&gt;&lt;span style=&quot;color:var(--ink-3);font-weight:500&quot;&gt;Author&lt;/span&gt;&lt;span style=&quot;color:var(--ink)&quot;&gt;Kim Dong-min&lt;/span&gt;&lt;span style=&quot;color:var(--ink-3);font-weight:500&quot;&gt;Published&lt;/span&gt;&lt;span style=&quot;color:var(--ink)&quot;&gt;March 27, 2026&lt;/span&gt;&lt;span style=&quot;color:var(--ink-3);font-weight:500&quot;&gt;Category&lt;/span&gt;&lt;span style=&quot;color:var(--ink)&quot;&gt;&lt;a href=&quot;#&quot; style=&quot;color:var(--accent)&quot;&gt;UI Design&lt;/a&gt;&lt;/span&gt;&lt;span style=&quot;color:var(--ink-3);font-weight:500&quot;&gt;Read time&lt;/span&gt;&lt;span style=&quot;color:var(--ink)&quot;&gt;4 min&lt;/span&gt;&lt;span style=&quot;color:var(--ink-3);font-weight:500&quot;&gt;Tags&lt;/span&gt;&lt;span style=&quot;display:flex;gap:5px;flex-wrap:wrap&quot;&gt;&lt;span style=&quot;background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1px 8px;font-size:10px;color:var(--ink-3)&quot;&gt;Design System&lt;/span&gt;&lt;span style=&quot;background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1px 8px;font-size:10px;color:var(--ink-3)&quot;&gt;Components&lt;/span&gt;&lt;span style=&quot;background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1px 8px;font-size:10px;color:var(--ink-3)&quot;&gt;Typography&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;" pos="0,0,560,160" renderHtml="true" textViewVariant="metadata" al="width:100%" editable="false" />
