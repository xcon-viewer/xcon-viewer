        weight 500
      textAlign "left"
      color @ink-3
      style "letter-spacing:2px;text-transform:uppercase;line-height:1.4;margin-top:18px;margin-bottom:12px;"
    meta: textView "<div style=\"display:grid;grid-template-columns:auto 1fr;gap:6px 16px;font-size:12px\"><span style=\"color:var(--ink-3);font-weight:500\">Author</span><span style=\"color:var(--ink)\">Kim Dong-min</span><span style=\"color:var(--ink-3);font-weight:500\">Published</span><span style=\"color:var(--ink)\">March 27, 2026</span><span style=\"color:var(--ink-3);font-weight:500\">Category</span><span style=\"color:var(--ink)\"><a href=\"#\" style=\"color:var(--accent)\">UI Design</a></span><span style=\"color:var(--ink-3);font-weight:500\">Read time</span><span style=\"color:var(--ink)\">4 min</span><span style=\"color:var(--ink-3);font-weight:500\">Tags</span><span style=\"display:flex;gap:5px;flex-wrap:wrap\"><span style=\"background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1px 8px;font-size:10px;color:var(--ink-3)\">Design System</span><span style=\"background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1px 8px;font-size:10px;color:var(--ink-3)\">Components</span><span style=\"background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:1px 8px;font-size:10px;color:var(--ink-3)\">Typography</span></span></div>" at 0 0 560 160
      renderHtml true
      textViewVariant "metadata"
