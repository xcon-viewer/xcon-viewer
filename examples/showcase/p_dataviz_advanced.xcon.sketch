    data {"nodes":[{"id":"viewer","label":"Viewer"},{"id":"core","label":"Core"},{"id":"site","label":"Site"},{"id":"docs","label":"Docs"},{"id":"examples","label":"Examples"}],"links":[{"source":"viewer","target":"core"},{"source":"viewer","target":"site"},{"source":"site","target":"docs"},{"source":"docs","target":"examples"}]}

  plotLabel: label "Plot" at 652 360 260 24
