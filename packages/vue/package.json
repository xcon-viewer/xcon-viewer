{
  "name": "@xcon-viewer/vue",
  "version": "0.1.6",
  "type": "module",
  "description": "Vue wrapper for rendering public XCON Viewer documents.",
  "keywords": [
    "xcon",
    "xcon-viewer",
    "vue",
    "ui-document",
    "viewer"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xcon-viewer/xcon-viewer.git",
    "directory": "packages/vue"
  },
  "homepage": "https://xconviewer.dev",
  "bugs": {
    "url": "https://github.com/xcon-viewer/xcon-viewer/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && tsc -b tsconfig.json --force --emitDeclarationOnly",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run test && npm run build"
  },
  "dependencies": {
    "@xcon-viewer/core": "0.1.6",
    "@xcon-viewer/viewer": "0.1.6"
  },
  "peerDependencies": {
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
