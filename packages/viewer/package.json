{
  "name": "@xcon-viewer/viewer",
  "version": "0.2.1",
  "type": "module",
  "description": "XCON viewer-only renderer. Renders XCON documents safely — scripts are blocked by design. Embed UI in Markdown, share from anyone, open anywhere.",
  "keywords": [
    "xcon",
    "xcon-viewer",
    "ui",
    "document",
    "viewer",
    "renderer",
    "web-component",
    "json",
    "xml",
    "tagless",
    "sketch",
    "llm",
    "markdown"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xcon-viewer/xcon-viewer.git",
    "directory": "packages/viewer"
  },
  "homepage": "https://xconviewer.dev",
  "bugs": {
    "url": "https://github.com/xcon-viewer/xcon-viewer/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./web-component": {
      "types": "./dist/web-component.d.ts",
      "import": "./dist/web-component.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && tsc -b tsconfig.json --force --emitDeclarationOnly",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run test && npm run build"
  },
  "dependencies": {
    "@observablehq/plot": "^0.6.17",
    "@xcon-viewer/core": "0.2.1",
    "d3": "^7.9.0",
    "d3-chord": "^3.0.1",
    "d3-force": "^3.0.0",
    "d3-hierarchy": "^3.1.2",
    "d3-sankey": "^0.12.3"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/d3-sankey": "^0.12.5",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
