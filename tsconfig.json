{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "composite": true
  },
  "files": [],
  "references": [
    { "path": "./packages/core" },
    { "path": "./packages/viewer" },
    { "path": "./packages/document-importer" },
    { "path": "./packages/cli" },
    { "path": "./packages/react" },
    { "path": "./packages/vue" },
    { "path": "./packages/markdown-it" },
    { "path": "./packages/remark" },
    { "path": "./packages/vite-plugin" },
    { "path": "./packages/github-action" }
  ],
  "exclude": ["node_modules", "dist", "**/dist", "drafts", ".temp"]
}
